{
  "schemaVersion": "haven.personal-chat.prompt-eval.v1",
  "name": "Personal Chat Purpose/Component Prompt Evaluation",
  "description": "Reusable prompt matrix for checking that PersonalChatHub maps natural language to purpose, interests and helper components without side effects. The same cases can later be run against Apple Intelligence, 4o-mini and other scoped provider cells.",
  "targetSurface": "Co-Pilot Chat",
  "defaultProviderUnderTest": "deterministic-v1",
  "futureProviders": [
    "binding.apple-intelligence",
    "binding.local-llm",
    "openai.4o-mini"
  ],
  "assertions": {
    "analyzeHasNoSideEffects": true,
    "openHelperHasNoSideEffects": true,
    "effectsRequireExplicitAction": true,
    "providersMustBeDeclaredInsideChatScope": true
  },
  "cases": [
    {
      "id": "invite.closest-colleague.nb",
      "locale": "nb-NO",
      "prompt": "inviter min nærmeste kollega",
      "setup": ["published-colleague-profile"],
      "expected": {
        "shouldSuggest": true,
        "intentKind": "invite_person",
        "purposeRef": "personal.chat.assist.invite",
        "suggestionStatus": "suggested",
        "helperID": "invite"
      }
    },
    {
      "id": "invite.ambiguous-colleague.nb",
      "locale": "nb-NO",
      "prompt": "inviter kollega",
      "setup": ["published-two-colleague-profiles"],
      "expected": {
        "shouldSuggest": true,
        "intentKind": "invite_person",
        "purposeRef": "personal.chat.assist.invite",
        "suggestionStatus": "needs_candidate_selection",
        "helperID": "invite",
        "minimumCandidateCount": 2
      }
    },
    {
      "id": "poll.group.nb",
      "locale": "nb-NO",
      "prompt": "vi trenger avstemning om lunsj",
      "setup": ["accepted-group-thread"],
      "expected": {
        "shouldSuggest": true,
        "intentKind": "create_poll",
        "purposeRef": "personal.chat.assist.poll",
        "suggestionStatus": "suggested",
        "helperID": "poll"
      }
    },
    {
      "id": "idea.capture.nb",
      "locale": "nb-NO",
